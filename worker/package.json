{
  "name": "@tg-crm/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma && node scripts/sync-prisma-client.js",
    "prisma:generate:safe": "prisma generate --schema ../api/prisma/schema.prisma && node scripts/sync-prisma-client.js || (echo [worker] prisma generate skipped: engine file is locked by another running process. & echo [worker] stop api/worker processes then run pnpm run prisma:generate once.)",
    "dev": "pnpm run prisma:generate:safe && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start": "pnpm run prisma:generate && node dist/main.js",
    "backfill:catalog-source": "pnpm run prisma:generate:safe && ts-node-dev --transpile-only src/scripts/catalog-source-backfill.ts",
    "reconcile:catalog-source": "pnpm run prisma:generate:safe && ts-node-dev --transpile-only src/scripts/catalog-source-reconcile-sample.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"lint placeholder\"",
    "format": "echo \"format placeholder\""
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.7.7",
    "bullmq": "^5.8.4",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5",
    "ioredis": "^5.4.1",
    "openai": "^6.27.0",
    "telegram": "^2.23.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "prisma": "6.19.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}