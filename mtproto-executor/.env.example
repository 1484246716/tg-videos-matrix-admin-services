# 运行环境：development / test / production
NODE_ENV=development

# mtproto-executor 服务端口
MTPROTO_EXECUTOR_PORT=3320

# 内部调用鉴权令牌（search-bot 调用本服务时需一致）
MTPROTO_EXECUTOR_INTERNAL_TOKEN=dev-mtproto-internal-token

# 是否启用 dry-run（true=只打印不真实发消息；false=启用真实 MTProto）
MTPROTO_DRY_RUN=true

# ===== MTProto 凭据（live 模式必填） =====
# Telegram API ID（数字）
MTPROTO_API_ID=

# Telegram API HASH
MTPROTO_API_HASH=

# GramJS String Session（已登录会话）
MTPROTO_STRING_SESSION=

# 备注：
# 1) 当 MTPROTO_DRY_RUN=false 时，上述 3 个 MTPROTO_* 参数必须填写。
# 2) 如你已有 apps/.env 的 GRAMJS_API_ID / GRAMJS_API_HASH / GRAMJS_SESSION，
#    建议后续在代码里做 fallback，避免维护两套配置。
# 3) 本服务仅做“注入 /start 并延时删除”执行，不替代 Bot Token 发送链路。
