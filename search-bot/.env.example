# 运行环境：development / test / production
NODE_ENV=development

# search-bot 服务监听端口（本地默认 3310）
SEARCH_BOT_PORT=3310

# Telegram Bot Token（测试环境请使用测试 Bot）
BOT_TOKEN=dev-bot-token

# Webhook 路径密钥（建议至少 32 位随机字符串）
# 同时用于 deep link 签名（一参两用）
BOT_WEBHOOK_SECRET=dev-webhook-secret

# Bot 用户名（不带 @），用于拼接 deep link
SEARCH_BOT_BOT_USERNAME=openclawtest1111_bot

# deep link 有效期（秒）
SEARCH_BOT_DEEPLINK_TTL_SEC=600

# 是否删除 /start 触发消息（私聊里增强体验）
SEARCH_BOT_START_DELETE_TRIGGER_MESSAGE=true

# search-bot 对外可访问的基地址（真实 Telegram 联调需公网 HTTPS）
SEARCH_BOT_WEBHOOK_BASE_URL=http://localhost:3310

# API 服务地址（search-bot 调用 /api/search/internal 的目标地址）
API_BASE_URL=http://localhost:3000

# search-bot 调用 API 的内部鉴权令牌（需与 API 侧配置一致）
API_INTERNAL_TOKEN=dev-internal-token

# Redis 连接地址（用于幂等、回调状态、缓存、限流）
REDIS_URL=redis://127.0.0.1:6379

# 回调 token 过期时间（秒）
SEARCH_BOT_CALLBACK_TTL_SEC=180

# 用户维度限流阈值（当前实现为分钟窗口内最大请求数）
SEARCH_BOT_USER_RATE_LIMIT=10

# copyMessage 失败最大重试次数（不含首尝试）
SEARCH_BOT_COPY_RETRY_MAX=1

# copyMessage 重试基础退避毫秒数
SEARCH_BOT_COPY_RETRY_BACKOFF_MS=200

# copy 幂等TTL（秒），防重复搬运
SEARCH_BOT_COPY_IDEMPOTENT_TTL_SEC=86400
