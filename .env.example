# Postgres 连接字符串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tg_crm?schema=public"

# Redis 连接字符串
REDIS_URL="redis://localhost:6379"

# 运行环境（development / production）
NODE_ENV="development"

# API 端口
PORT="3001"

# JWT 签名密钥
JWT_SECRET="replace_me"

# Telegram Bot API 本地服务地址
TELEGRAM_BOT_API_BASE="http://localhost:8081"

# 频道根目录（本地存储路径）
CHANNELS_ROOT_DIR=D:/Project/tg-videos-matrix/data/tg-crm/channels

# Relay 稳定性检查次数（达到该次数才认为稳定）
RELAY_MIN_STABLE_CHECKS=3

# Relay 稳定性检查间隔（毫秒）
RELAY_STABLE_INTERVAL_MS=10000

# Relay 文件变更冷却时间（毫秒）
RELAY_MTIME_COOLDOWN_MS=60000

# OpenAI API Key（文本生成备用）
OPENAI_API_KEY="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"

# OpenAI Base URL
OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# OpenAI 模型名称
OPENAI_MODEL="gpt-4o"

# GramJS 分布式上传
# GramJS API ID
GRAMJS_API_ID=6

# GramJS API Hash
GRAMJS_API_HASH=eb06d4abfb49dc3eeb1aeb98ae0f581e

# GramJS Bot Token
GRAMJS_BOT_TOKEN=8750770784:AAHBNH12DzFL8DB7f7r967IW9BRwn3NZ6p0

# GramJS Session（授权会话）
GRAMJS_

# GramJS 上传阈值（超过该大小使用 GramJS，单位 MB）
RELAY_UPLOAD_GRAMJS_THRESHOLD_MB=20

# 上传方式阈值（超过该大小使用 sendDocument，否则 sendVideo，单位 MB）
RELAY_UPLOAD_SEND_DOCUMENT_THRESHOLD_MB=900

# GramJS 转发目标 Chat ID（可选，不填默认用中转频道）
GRAMJS_FORWARD_TARGET_CHAT_ID=

# GramJS 并发上传 Worker 数量
GRAMJS_UPLOAD_WORKERS=16

